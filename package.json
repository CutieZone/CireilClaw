{
  "name": "cireilclaw-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "start": "pnpm --filter cireilclaw-runtime start",
    "test": "pnpm --filter cireilclaw-runtime test",
    "test:watch": "pnpm --filter cireilclaw-runtime test:watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "publish:all": "pnpm publish -r --filter='@cireilclaw/*'"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
