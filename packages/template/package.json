{
  "name": "@cireilclaw/plugin-template",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "tsdown"
  },
  "devDependencies": {
    "@cireilclaw/sdk": "workspace:*",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@cireilclaw/sdk": "^0.4.0"
  }
}
