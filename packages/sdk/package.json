{
  "name": "@cireilclaw/sdk",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "tsdown"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "heic-decode": "^2.1.0",
    "sharp": "^0.34.5",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/heic-decode": "^1.1.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
