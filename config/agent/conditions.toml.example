# Per-agent conditions configuration
# Copy to ~/.cireilclaw/agents/{slug}/config/conditions.toml
#
# Supported conditions: discord:nsfw, discord:dm, discord:dm:{channelId},
#   discord:guild:{guildId}, discord:channel:{channelId}, tui, internal
# Negation is supported with a leading `!` (e.g., `!discord:nsfw`, `!tui`)

# --- Block loading rules ---
# Each rule loads a memory block from blocks/conditional/ when conditions match.
# [blocks.nsfw-personality]
# action = "load"
# when = "discord:nsfw"
# mode = "or"                  # "and" or "or". Default: "or"

# --- Path access rules (memories and workspace) ---
# Paths ending with "/" match as prefixes. Others require exact match.
# Evaluation order: deny rules → allow rules → default (allow if no rules match).
#
# [memories."/private/"]
# action = "deny"
# when = ["discord:guild:123456789", "tui"]
# mode = "and"
#
# [workspace."/project-x/"]
# action = "allow"
# when = "discord:channel:987654321"
